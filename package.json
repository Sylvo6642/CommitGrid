{
  "name": "commitgrid",
  "version": "0.2.3",
  "description": "A animated GitHub contributions graph React component",
  "author": "Kevin Robin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "testbed": "vite"
  },
  "peerDependencies": {
    "framer-motion": ">=10",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "framer-motion": "^11.3.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.12"
  },
  "keywords": [
    "github",
    "contributions",
    "graph",
    "heatmap",
    "react",
    "calendar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinrobin/github-contributions-graph"
  }
}
